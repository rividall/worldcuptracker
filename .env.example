# Docker Compose project name (used for container naming)
COMPOSE_PROJECT_NAME=worldcup

# PostgreSQL
POSTGRES_USER=worldcup
POSTGRES_PASSWORD=changeme
POSTGRES_DB=worldcup

# Backend
DATABASE_URL=postgresql+asyncpg://worldcup:changeme@db:5432/worldcup
SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3007,https://worldcup.buenalynch.com

# football-data.org (free tier: 10 req/min — hourly sync is well within limits)
# Get a key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=CHANGE_ME
FOOTBALL_DATA_COMPETITION=WC
FETCH_INTERVAL_MINUTES=60
# Faster sync cadence while a match is live or in its kickoff window.
LIVE_FETCH_INTERVAL_MINUTES=2

# Ports (host-side)
# 3007/8006 assigned per _lynchProtocol/SERVER-INFRASTRUCTURE.md port map.
# DB_PORT is local-dev convenience only; postgres stays internal in production.
DB_PORT=5437
BACKEND_PORT=8006
FRONTEND_PORT=3007

# Frontend (build-time)
VITE_API_URL=/api/v1
